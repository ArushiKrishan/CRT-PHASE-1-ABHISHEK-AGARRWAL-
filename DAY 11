class Solution {
public:
    void reverseString(vector<char>& s) {
       int n;
      int start = 0;
       int end = s.size()-1;
        while(start<end) {
            char c = s[start];
            s[start] = s[end];
            s[end] = c;
            start++;
            end--;
        }
    }
};


