// program 1 -- Making a 2D Arrays

#include <iostream>
using namespace std;

int main() {
    int arr[2][2];
    
    for(int i=0; i<2; i++) {
        for(int j=0; j<2; j++){
            cin>>arr[i][j];
        }
    }
    cout<<"Here is your 2 day array"<<"\n";
    for(int i=0; i<2; i++) {
        for(int j=0; j<2; j++){
            cout<<arr[i][j]<<" ";
        }
        cout<<"\n";
    }
    return 0;
}


// program 2 -- Sum of elements of 2D Arrays

#include <iostream>
using namespace std;

int main() {
    int arr[2][2];
    int sum=0;
    
    
    for(int i=0; i<2; i++) {
        for(int j=0; j<2; j++){
            cin>>arr[i][j];
            sum=sum+arr[i][j];
        }
    }
    cout<<sum;
}


// program 3 -- Search an element in a 2D Arrays

#include <iostream>
using namespace std;

int main() {
    int arr[2][2] = { {10,20},
                    {30,40} };
    int searchElement;
    cin >> searchElement;
    
    for(int i=0; i<2; i++) {
        for(int j=0; j<2; j++){
            if(arr[i][j] == searchElement) {
                cout<<i<<" "<<j;
                return 0;
            }
        }
    }
    cout<<"Element not found";
}
