// problem-5 (print 10 to 1 using while loop)

#include <iostream>
using namespace std;

int main() {
    int i = 10;
    while(i >= 1) {
        cout << i << " ";
        i--;
    }
    
    }

// problem-6 (print 10 to 1 using do-while loop)

#include <iostream>
using namespace std;

int main() {
    int i = 1;
    do {
        cout << i << " ";
        i++;
    } while (i <= 10);
    }

// problem-7 (print factorial of given numbers)

#include <iostream>
using namespace std;

int main() {
    int n;
    int i;
    cin >> n;
    int fact = 1;
    
    for(int i =n; i>=1; i--) {
        fact = fact * i;
        
    }
    cout << fact;
}

// problem-8 (check wheater the number is prime number or not)

#include <iostream>
using namespace std;

int main() {
    int n;
    bool isprime = true;
    cin >> n;
    
    if(n<2) {
        isprime = false;
    } else {
        for(int i = 2; i < n; i++){
            if(n % i == 0) {
                isprime = false;
                break;
            }
        }
    }
    
    if(isprime) {
        cout << "It is a prime number";
    } else {
        cout << "It is not a prime number";
    }
}
 
