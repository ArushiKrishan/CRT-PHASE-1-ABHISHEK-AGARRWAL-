// problem 1 -- Types of Inheritance -- Single Inheritance

#include <iostream>
using namespace std;

class Vehicle {
    public:
    void start() {
        cout<<"Vehicle starts"<<"\n";
    }
};

class Car : public Vehicle {
    public:
    void drive() {
        cout<<"Car is running"<<"\n";
    }
};

int main() {
  Car obj1;
  obj1.drive();
  obj1.start();
}


// problem 2 -- Types of Inheritance -- Multi-level Inheritance

#include <iostream>
using namespace std;

class Vehicle {
    public:
    void start() {
        cout<<"Vehicle starts"<<"\n";
    }
};

class Car : public Vehicle {
    public:
    void drive() {
        cout<<"Car is running"<<"\n";
    }
};

class speedOMeter : public Car {
    public :
    void speed() {
        cout<<"Car is running at 60km/h"<<"\n";
    }
};

int main() {
  speedOMeter obj1;
  obj1.start();
  obj1.drive();
  obj1.speed();
}


