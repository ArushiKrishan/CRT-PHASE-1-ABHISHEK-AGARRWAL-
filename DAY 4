// problem-5 (print a hollow square with star pattern)

#include<iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
   
    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= n; j++) {
            if(i == 1 || i == n || j == 1 || j == n){
                cout << "*";
            } else {
                cout << " ";
            }
            
        }
        cout << "\n";
    }
    
}

