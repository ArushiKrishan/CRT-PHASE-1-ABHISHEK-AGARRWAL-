// Problem 1-- convert celcius to fahrenheit

#include <iostream>
using namespace std;

int  main(){
double celcius;
double fahrenheit;
cin >> celcius;

fahrenheit=(celcius*9.0/5.0)+3.2;
cout << fahrenheit << endl;
return 0;
}


// Problem 2-- Local and global variable

#include <iostream>
